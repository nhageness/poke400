     A  41                                  COLOR(WHT)
     A  42                                  COLOR(RED)
     A  43                                  COLOR(TRQ)
     A  44                                  COLOR(YLW)
     A  45                                  COLOR(PNK)
     A  46                                  COLOR(BLU)
